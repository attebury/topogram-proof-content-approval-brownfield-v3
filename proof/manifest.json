{
  "version": 3,
  "repository": "topogram-proof-content-approval-brownfield-v3",
  "story": "real-ish brownfield app, package-backed extractors, reviewable adoption, agent-safe maintained change, drift refresh, and cross-stack recreation",
  "topogramCliVersion": "0.3.99",
  "expectedTags": [
    "proof-01-brownfield-baseline",
    "proof-02-extract-with-packages",
    "proof-03-adopt-app-map",
    "proof-04-feature-from-slice",
    "proof-05-refresh-drift",
    "proof-06-recreate-other-stack"
  ],
  "requiresCanonicalTopo": true,
  "requiresSdlc": true,
  "forbidsCanonicalTopo": false,
  "requiresRecreatedCompile": true,
  "appCheckScript": "check",
  "requiredArtifacts": [
    {
      "path": "proof/artifacts/path-hygiene-audit.json",
      "json": true,
      "type": "proof_path_hygiene_audit"
    },
    {
      "path": "proof/STEP.md",
      "contains": [
        "Step"
      ]
    },
    {
      "path": "proof/artifacts/step-01-npm-verify.txt",
      "contains": [
        "verified"
      ]
    },
    {
      "path": "proof/artifacts/step-02-extracted-topogram/proof/artifacts/step-02-extract.json",
      "json": true,
      "keys": [
        "candidateCounts"
      ]
    },
    {
      "path": "proof/artifacts/step-02-extracted-topogram/proof/artifacts/step-02-extract-plan.json",
      "json": true,
      "keys": [
        "commands"
      ]
    },
    {
      "path": "proof/artifacts/step-02-extracted-topogram/proof/artifacts/step-02-extractor-list.json",
      "json": true,
      "keys": [
        "extractors"
      ]
    },
    {
      "path": "proof/artifacts/step-02-extracted-topogram/proof/artifacts/step-02-extractor-policy-status.json",
      "json": true,
      "keys": [
        "policy"
      ]
    },
    {
      "path": "proof/artifacts/step-03-agent-brief.json",
      "json": true,
      "type": "agent_brief"
    },
    {
      "path": "proof/artifacts/step-03-check.json",
      "json": true,
      "keys": [
        "ok"
      ]
    },
    {
      "path": "proof/artifacts/step-03-adopt-list.json",
      "json": true,
      "keys": [
        "broadSelectors"
      ]
    },
    {
      "path": "proof/artifacts/step-03-adopt-write.json",
      "json": true,
      "keys": [
        "adoption"
      ]
    },
    {
      "path": "proof/artifacts/step-04-single-agent-plan.json",
      "json": true,
      "type": "single_agent_plan"
    },
    {
      "path": "proof/artifacts/step-04-npm-verify.txt",
      "contains": [
        "verified"
      ]
    },
    {
      "path": "proof/artifacts/step-05-extract-diff.json",
      "json": true,
      "keys": [
        "candidateCountDeltas"
      ]
    },
    {
      "path": "proof/artifacts/step-05-extract-refresh.json",
      "json": true,
      "keys": [
        "candidateCounts"
      ]
    },
    {
      "path": "proof/artifacts/step-06-generate.txt",
      "contains": [
        "Wrote"
      ]
    },
    {
      "path": "proof/artifacts/step-06-recreated-app-compile.txt",
      "contains": [
        "Compile checks passed"
      ]
    }
  ]
}
