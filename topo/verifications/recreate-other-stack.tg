verification verification_recreate_other_stack {
  name "Recreate Other Stack Verification"
  description "Runs Topogram check, generation into recreated-app, generated compile, maintained app verification, and SDLC check."
  validates [cap_list_submissions, cap_get_submission, cap_submit_content, cap_approve_submission, cap_request_changes, cap_bulk_approve_submissions]
  method runtime
  scenarios [brownfield_generated_recreation_compile_maintained_source_preserved]
  status active
}
