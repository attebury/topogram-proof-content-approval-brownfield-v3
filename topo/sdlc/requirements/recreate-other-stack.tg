requirement req_recreate_other_stack {
  name "Recreate Other Stack"
  description "The brownfield proof must generate a separate SvelteKit/Hono/Postgres app from the adopted Topogram without overwriting maintained React/Express/Prisma source."
  affects [cap_list_submissions, cap_get_submission, cap_submit_content, cap_approve_submission, cap_request_changes, cap_bulk_approve_submissions]
  introduces_rules []
  respects_rules []
  priority medium
  status approved
}
