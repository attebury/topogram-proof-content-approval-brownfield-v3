requirement req_parity_proof {
  name "Parity Proof"
  description "The brownfield proof must compare maintained and recreated stacks using Topogram contracts, query packets, and verification summaries."
  affects [cap_list_submissions, cap_get_submission, cap_submit_content, cap_approve_submission, cap_request_changes, cap_bulk_approve_submissions]
  introduces_rules []
  respects_rules []
  priority medium
  status approved
}
