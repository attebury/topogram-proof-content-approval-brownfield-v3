{
  "type": "db_lifecycle_plan",
  "projection": {
    "id": "proj_db_postgres",
    "name": "Content Approval Postgres DB",
    "type": "db_contract"
  },
  "engine": "postgres",
  "dbProfile": "postgres_sql",
  "ormProfiles": [
    "prisma",
    "drizzle"
  ],
  "runtimeProfile": "prisma",
  "inputPath": "./topo",
  "migrationStrategy": {
    "ownership": "generated",
    "tool": "sql",
    "apply": "script",
    "statePath": null,
    "snapshotPath": null,
    "schemaPath": null,
    "migrationsPath": null,
    "defaulted": true
  },
  "state": {
    "root": "state",
    "currentSnapshot": "state/current.snapshot.json",
    "desiredSnapshot": "state/desired.snapshot.json",
    "migrationPlan": "state/migration.plan.json",
    "migrationSql": "state/migration.sql"
  },
  "bundle": {
    "emptySnapshot": "snapshots/empty.snapshot.json",
    "prismaSchema": "prisma/schema.prisma",
    "drizzleSchema": "drizzle/schema.ts"
  },
  "proposals": {
    "schemaPath": null,
    "migrationsPath": null,
    "snapshotPath": null
  },
  "environment": {
    "required": [
      "DATABASE_URL"
    ],
    "optional": [
      "DATABASE_ADMIN_URL",
      "TOPOGRAM_BIN",
      "TOPOGRAM_INPUT_PATH",
      "TOPOGRAM_DB_STATE_DIR"
    ]
  },
  "greenfield": {
    "detection": "missing current snapshot",
    "provisioning": "create database when DATABASE_ADMIN_URL is available, otherwise assume DATABASE_URL already points at a provisioned database",
    "setup": [
      "generate desired schema snapshot",
      "generate initial SQL migration from the bundled empty snapshot",
      "apply SQL to the target database",
      "run prisma generate against the bundled schema",
      "persist desired snapshot as current"
    ]
  },
  "brownfield": {
    "detection": "existing current snapshot",
    "setup": [
      "generate desired schema snapshot",
      "diff current snapshot against desired snapshot",
      "stop if manual intervention is required",
      "generate additive SQL migration",
      "apply SQL to the target database",
      "run prisma generate against the bundled schema",
      "persist desired snapshot as current"
    ],
    "safety": "manual migration required plans are never auto-applied"
  },
  "behavior": {
    "ownership": "generated",
    "tool": "sql",
    "apply": "script",
    "appliesMigrations": true,
    "writesGeneratedState": true,
    "proposalOnly": false
  },
  "reviewWorkflow": {
    "mode": "generated_apply",
    "proposalOnly": false,
    "tool": "sql",
    "applyBoundary": "Topogram owns generated database lifecycle scripts and may apply supported generated SQL migrations.",
    "snapshotSource": "state/current.snapshot.json",
    "commands": [
      {
        "id": "desired_snapshot",
        "label": "Emit the desired DB schema snapshot from the current Topogram",
        "command": "topogram emit db-schema-snapshot ./topo --projection proj_db_postgres --json",
        "output": "state/desired.snapshot.json"
      },
      {
        "id": "migration_plan",
        "label": "Compare the trusted current snapshot to the desired snapshot",
        "command": "topogram emit db-migration-plan ./topo --projection proj_db_postgres --from-snapshot state/current.snapshot.json --json",
        "output": "state/migration.plan.json"
      },
      {
        "id": "sql_proposal",
        "label": "Emit a SQL proposal for review",
        "command": "topogram emit sql-migration ./topo --projection proj_db_postgres --from-snapshot state/current.snapshot.json --write --out-dir ./db-proposals/sql",
        "output": "state/migration.sql"
      },
      {
        "id": "prisma_schema_proposal",
        "label": "Emit a Prisma schema proposal for review",
        "command": "topogram emit prisma-schema ./topo --projection proj_db_postgres --write --out-dir ./db-proposals/prisma",
        "output": "db-proposals/prisma/schema.prisma"
      },
      {
        "id": "drizzle_schema_proposal",
        "label": "Emit a Drizzle schema proposal for review",
        "command": "topogram emit drizzle-schema ./topo --projection proj_db_postgres --write --out-dir ./db-proposals/drizzle",
        "output": "db-proposals/drizzle/schema.ts"
      },
      {
        "id": "lifecycle_bundle",
        "label": "Emit a repeatable lifecycle proposal bundle",
        "command": "topogram emit db-lifecycle-bundle ./topo --projection proj_db_postgres --write --out-dir ./db-proposals/lifecycle",
        "output": "db-proposals/lifecycle"
      }
    ],
    "handoffSteps": [
      "Run the generated lifecycle scripts from the generated database bundle.",
      "Stop and review manually when the migration plan reports unsupported or destructive changes.",
      "After a generated migration succeeds, Topogram records the current snapshot at state/current.snapshot.json."
    ]
  }
}
