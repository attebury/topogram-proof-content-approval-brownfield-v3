# Environment profile
TOPOGRAM_ENVIRONMENT_PROFILE=local_process

# Local stack ports
DB_PORT=5433
SERVER_PORT=3100
WEB_PORT=5174

# Local Postgres defaults
POSTGRES_DB=topogram_content_approval
POSTGRES_USER=${USER:-postgres}
POSTGRES_PASSWORD=postgres

# Local shell/runtime defaults
DATABASE_URL=postgresql://${POSTGRES_USER}@localhost:5433/topogram_content_approval?schema=public
DATABASE_ADMIN_URL=postgresql://${POSTGRES_USER}@localhost:5433/postgres
PUBLIC_TOPOGRAM_API_BASE_URL=http://localhost:3100
TOPOGRAM_CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
PUBLIC_TOPOGRAM_DEMO_USER_ID=
TOPOGRAM_DEMO_USER_ID=
PUBLIC_TOPOGRAM_DEMO_PRIMARY_ID=33333333-3333-4333-8333-333333333333
TOPOGRAM_DEMO_PRIMARY_ID=33333333-3333-4333-8333-333333333333
TOPOGRAM_DEMO_BODY="Draft content waiting for editorial approval."
TOPOGRAM_SEED_DEMO=true
