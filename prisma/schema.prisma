generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContentSubmission {
  id                String    @id @db.Uuid
  title             String
  body              String
  status            String
  review_priority   String?
  assigned_reviewer String?
  author_name       String
  created_at        DateTime  @db.Timestamptz(3)
  submitted_at      DateTime  @db.Timestamptz(3)
  reviewed_at       DateTime? @db.Timestamptz(3)
  reviewer_note     String?

  @@index([status])
  @@index([review_priority])
  @@index([assigned_reviewer])
  @@index([submitted_at])
  @@map("content_submissions")
}
